APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:ZXS9gyJVLs7DiiUcKlW77LZ16BnNsjK2mjn0PYcityE=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────────────
# Untuk development/testing, gunakan 'log' (email ditulis ke log, tidak dikirim)
# Untuk production, ganti ke 'smtp' dan isi kredensial Gmail di bawah
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=emailkamu@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
MAIL_FROM_ADDRESS="noreply@upcireng.com"
MAIL_FROM_NAME="UP Cireng"

# ── Admin ─────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@email.com

# ── Integrasi lain ────────────────────────────────────────────────────────
FONNTE_TOKEN=ISI_TOKEN
GSHEET_WEBHOOK=https://script.google.com/macros/s/XXX/exec

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"